@inject IIdentifyService IdentifyService
@inject IMetadataProviderResolver Resolver

<Modal Visible="Visible" Title="@($"Identify · {ItemTitle}")" OnClose="OnClose">
    <div class="space-y-4">
        @if (error is not null)
        {
            <p class="rounded border border-red-500/40 bg-red-500/10 px-3 py-2 text-sm text-red-300">@error</p>
        }

        <div class="flex gap-2">
            <select class="rounded border border-slate-700 bg-slate-800 px-2 py-2 text-sm text-white" @bind="source">
                @foreach (var s in availableSources)
                {
                    <option value="@s">@Label(s)</option>
                }
            </select>
            <select class="rounded border border-slate-700 bg-slate-800 px-2 py-2 text-sm text-white" @bind="searchMode">
                <option value="title">By title</option>
                <option value="id">By ID</option>
            </select>
            <input class="min-w-0 flex-1 rounded border border-slate-700 bg-slate-800 px-3 py-2 text-sm text-white"
                   @bind="query" @bind:event="oninput" @onkeydown="OnKeyDown"
                   placeholder="@(byId ? $"{Label(source)} id, e.g. {IdExample(source)}" : "Search title…")" />
            <button class="rounded bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-500 disabled:opacity-50"
                    @onclick="Search" disabled="@busy">
                @(byId ? "Look up" : "Search")
            </button>
        </div>

        @if (busy)
        {
            <p class="text-sm text-slate-400">Working…</p>
        }
        else if (results is { Count: 0 })
        {
            <p class="text-sm text-slate-400">No results.</p>
        }

        @if (results is { Count: > 0 })
        {
            @if (LibraryType == LibraryType.TvShows)
            {
                <p class="text-xs text-slate-500">
                    Pick the episode order your files follow — episode 1 of that order maps to S01E01.
                </p>
            }

            <div class="max-h-96 space-y-2 overflow-y-auto pr-1">
                @foreach (var r in results)
                {
                    <div class="flex gap-3 rounded-lg border border-slate-800 p-2">
                        <div class="flex h-24 w-16 shrink-0 items-center justify-center overflow-hidden rounded bg-slate-800 text-slate-600">
                            @if (r.PosterUrl is not null)
                            {
                                <img src="@r.PosterUrl" class="h-full w-full object-cover" alt="" />
                            }
                            else
                            {
                                <span class="text-xs">No image</span>
                            }
                        </div>
                        <div class="min-w-0 flex-1">
                            <div class="font-medium text-white">
                                @r.Title <span class="text-slate-400">@(r.Year?.ToString())</span>
                            </div>
                            <p class="mt-1 line-clamp-2 text-xs text-slate-400">@r.Overview</p>
                            @if (LibraryType == LibraryType.TvShows)
                            {
                                <div class="mt-2 flex items-center gap-2">
                                    <span class="shrink-0 text-xs text-slate-500">Order</span>
                                    <select class="min-w-0 flex-1 rounded border border-slate-700 bg-slate-800 px-2 py-1 text-xs text-white"
                                            value="@SelectedOrderingId(r.ProviderId)"
                                            @onchange="e => SetOrdering(r.ProviderId, e.Value?.ToString())">
                                        <option value="">Aired order (default)</option>
                                        @foreach (var o in OrderingsFor(r.ProviderId))
                                        {
                                            <option value="@o.Id">@OrderingLabel(o)</option>
                                        }
                                    </select>
                                    @if (orderingsLoading.Contains(r.ProviderId))
                                    {
                                        <span class="shrink-0 text-xs text-slate-600">checking…</span>
                                    }
                                </div>
                            }
                        </div>
                        <button class="self-start rounded bg-sky-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-sky-500 disabled:opacity-50"
                                @onclick="() => Match(r)" disabled="@busy">
                            Match
                        </button>
                    </div>
                }
            </div>
        }
    </div>
</Modal>

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public Guid ItemId { get; set; }
    [Parameter] public string ItemTitle { get; set; } = string.Empty;
    [Parameter] public int? ItemYear { get; set; }
    [Parameter] public LibraryType LibraryType { get; set; }
    [Parameter] public MetadataSource PreferredSource { get; set; } = MetadataSource.Tmdb;
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnLinked { get; set; }

    private List<MetadataSource> availableSources = [];
    private MetadataSource source = MetadataSource.Tmdb;
    private string searchMode = "title";
    private bool byId => searchMode == "id";
    private string query = string.Empty;
    private List<MetadataSearchResult>? results;
    private bool busy;
    private string? error;
    private Guid loadedFor;

    // Episode orderings (TMDB episode groups) per show result, loaded right after a search so the inline
    // picker is populated without an extra step. Keyed by provider id; the selected id ("" = aired order).
    private readonly Dictionary<string, IReadOnlyList<EpisodeOrdering>> orderingsByShow = [];
    private readonly Dictionary<string, string> selectedOrderingByShow = [];
    private readonly HashSet<string> orderingsLoading = [];

    protected override async Task OnParametersSetAsync()
    {
        if (Visible && ItemId != loadedFor)
        {
            // New target opened — reset and auto-search.
            loadedFor = ItemId;
            availableSources = Resolver.ProvidersFor(LibraryType).Select(p => p.Source).ToList();
            source = availableSources.Contains(PreferredSource)
                ? PreferredSource
                : availableSources.FirstOrDefault(MetadataSource.Tmdb);
            query = ItemTitle;
            results = null;
            error = null;
            ResetOrderings();
            await Search();
        }
        else if (!Visible)
        {
            loadedFor = Guid.Empty;
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await Search();
        }
    }

    private async Task Search()
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            return;
        }

        busy = true;
        error = null;
        ResetOrderings();
        try
        {
            if (byId)
            {
                var hit = await IdentifyService.LookupByIdAsync(source, query.Trim(), LibraryType);
                results = hit is null ? [] : [hit];
            }
            else
            {
                results = (await IdentifyService.SearchAsync(source, query, ItemYear, LibraryType)).ToList();
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
            results = null;
        }
        finally
        {
            busy = false;
        }

        // For shows, fetch each result's alternate orderings in the background so the inline picker fills in.
        if (LibraryType == LibraryType.TvShows && results is { Count: > 0 })
        {
            foreach (var r in results)
            {
                _ = LoadOrderingsAsync(r.ProviderId);
            }
        }
    }

    private async Task LoadOrderingsAsync(string providerId)
    {
        if (orderingsByShow.ContainsKey(providerId) || !orderingsLoading.Add(providerId))
        {
            return;
        }
        try
        {
            orderingsByShow[providerId] = await IdentifyService.GetEpisodeOrderingsAsync(source, providerId);
        }
        catch
        {
            // Orderings are an enhancement; on failure just offer aired order for this show.
            orderingsByShow[providerId] = [];
        }
        finally
        {
            orderingsLoading.Remove(providerId);
            await InvokeAsync(StateHasChanged);
        }
    }

    // Match a result using whatever order is selected for it (aired order when nothing is picked).
    private Task Match(MetadataSearchResult result)
    {
        var id = SelectedOrderingId(result.ProviderId);
        var ordering = string.IsNullOrEmpty(id)
            ? null
            : OrderingsFor(result.ProviderId).FirstOrDefault(o => o.Id == id);
        return Link(result, ordering);
    }

    private async Task Link(MetadataSearchResult result, EpisodeOrdering? ordering)
    {
        busy = true;
        error = null;
        try
        {
            await IdentifyService.LinkAsync(ItemId, result, ordering);
            await OnLinked.InvokeAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }

    private void ResetOrderings()
    {
        orderingsByShow.Clear();
        selectedOrderingByShow.Clear();
        orderingsLoading.Clear();
    }

    private IReadOnlyList<EpisodeOrdering> OrderingsFor(string providerId) =>
        orderingsByShow.TryGetValue(providerId, out var o) ? o : [];

    // "" selects "Aired order (default)".
    private string SelectedOrderingId(string providerId) =>
        selectedOrderingByShow.TryGetValue(providerId, out var id) ? id : string.Empty;

    private void SetOrdering(string providerId, string? id) =>
        selectedOrderingByShow[providerId] = id ?? string.Empty;

    private static string OrderingLabel(EpisodeOrdering o) =>
        o.EpisodeCount > 0 ? $"{o.Name} · {o.EpisodeCount} episodes" : o.Name;

    private static string Label(MetadataSource s) => s switch
    {
        MetadataSource.Tmdb => "TMDB",
        MetadataSource.Tvdb => "TVDB",
        MetadataSource.Imdb => "IMDb",
        _ => s.ToString(),
    };

    private static string IdExample(MetadataSource s) => s switch
    {
        MetadataSource.Imdb => "tt1375666",
        _ => "27205",
    };
}
