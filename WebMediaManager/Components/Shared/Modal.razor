@if (Visible)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 p-4" @onclick="OnBackdrop">
        <div class="w-full @MaxWidthClass rounded-lg border border-slate-700 bg-slate-900 shadow-xl"
             @onclick:stopPropagation="true">
            <div class="flex items-center justify-between border-b border-slate-800 px-5 py-3">
                <h2 class="text-lg font-semibold text-white">@Title</h2>
                <button class="text-slate-400 hover:text-white" @onclick="Close" aria-label="Close">✕</button>
            </div>
            <div class="px-5 py-4">
                @ChildContent
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public string MaxWidthClass { get; set; } = "max-w-lg";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public bool CloseOnBackdrop { get; set; } = true;

    private Task Close() => OnClose.InvokeAsync();

    private Task OnBackdrop() => CloseOnBackdrop ? OnClose.InvokeAsync() : Task.CompletedTask;
}
