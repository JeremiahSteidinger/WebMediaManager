@page "/item/{Id:guid}"
@using WebMediaManager.Core.Scanning
@inject IMediaService MediaService
@inject ISettingsService SettingsService
@inject IIdentifyService IdentifyService

<PageTitle>@(item?.Title ?? "Item")</PageTitle>

@if (item is null)
{
    <p class="mt-6 text-slate-400">@(loaded ? "Item not found." : "Loading…")</p>
}
else
{
    <a class="text-sm text-slate-400 hover:text-white" href="@($"library/{item.LibraryId}")">← Back to library</a>

    <div class="mt-2 flex items-start justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-white">
                @item.Title <span class="font-normal text-slate-400">@(item.Year?.ToString())</span>
            </h1>
            <div class="mt-1 flex items-center gap-2">
                <span class="@BadgeClass(item.MatchState)">@item.MatchState</span>
                @if (item.HasNfo)
                {
                    <span class="rounded bg-sky-500/20 px-2 py-0.5 text-xs font-medium text-sky-300" title="Identified outside this app — an NFO file was found">NFO</span>
                }
            </div>
        </div>
        <div class="flex gap-2">
            @if (item is Movie { VideoFilePath.Length: > 0 })
            {
                <button class="rounded border border-slate-700 px-4 py-2 text-sm text-slate-200 hover:bg-slate-800" @onclick="() => showPlayer = !showPlayer">
                    @(showPlayer ? "Stop" : "▶ Play")
                </button>
            }
            <button class="rounded bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-500" @onclick="() => showIdentify = true">
                Identify
            </button>
            <button class="rounded border border-slate-700 px-4 py-2 text-sm text-slate-200 hover:bg-slate-800" @onclick="() => showRename = true">
                Rename
            </button>
        </div>
    </div>

    <div class="mt-6 flex flex-col gap-6 md:flex-row">
        <div class="w-48 shrink-0">
            <div class="relative flex aspect-[2/3] items-center justify-center overflow-hidden rounded-lg bg-slate-800 text-4xl font-bold text-slate-600">
                @InitialOf(item.Title)
                <img src="@($"art/{item.Id}")" alt="" class="absolute inset-0 h-full w-full object-cover" onerror="this.remove()" />
            </div>
        </div>

        <div class="min-w-0 flex-1 space-y-4">
            @if (!string.IsNullOrWhiteSpace(item.Plot))
            {
                <p class="text-sm leading-relaxed text-slate-300">@item.Plot</p>
            }

            <dl class="grid grid-cols-2 gap-x-6 gap-y-2 text-sm sm:grid-cols-3">
                @if (item.Genres.Count > 0)
                {
                    <div class="col-span-2 sm:col-span-3">
                        <dt class="text-slate-500">Genres</dt>
                        <dd class="text-slate-200">@string.Join(", ", item.Genres)</dd>
                    </div>
                }
                @if (item.Rating is { } rating)
                {
                    <div><dt class="text-slate-500">Rating</dt><dd class="text-slate-200">@rating.ToString("0.0")</dd></div>
                }
                @if (item is Movie { Runtime: { } runtime })
                {
                    <div><dt class="text-slate-500">Runtime</dt><dd class="text-slate-200">@runtime min</dd></div>
                }
                @if (item is TvShow show && show.Status != TvShowStatus.Unknown)
                {
                    <div><dt class="text-slate-500">Status</dt><dd class="text-slate-200">@show.Status</dd></div>
                }
                @if (item is TvShow { EpisodeGroupName: { Length: > 0 } orderName })
                {
                    <div><dt class="text-slate-500">Episode order</dt><dd class="text-slate-200">@orderName</dd></div>
                }
                @if (!string.IsNullOrEmpty(item.TmdbId))
                {
                    <div><dt class="text-slate-500">TMDB</dt><dd class="text-slate-200">@item.TmdbId</dd></div>
                }
                @if (!string.IsNullOrEmpty(item.TvdbId))
                {
                    <div><dt class="text-slate-500">TVDB</dt><dd class="text-slate-200">@item.TvdbId</dd></div>
                }
                @if (!string.IsNullOrEmpty(item.ImdbId))
                {
                    <div><dt class="text-slate-500">IMDb</dt><dd class="text-slate-200">@item.ImdbId</dd></div>
                }
            </dl>

            <div>
                <dt class="text-xs text-slate-500">Path</dt>
                <dd class="font-mono text-xs text-slate-400">@item.RelativePath</dd>
            </div>
        </div>
    </div>

    @if (showPlayer && item is Movie { VideoFilePath.Length: > 0 } movieItem)
    {
        <div class="mt-6">
            <video controls autoplay playsinline class="max-h-[70vh] w-full rounded-lg bg-black"
                   src="@($"media/movie/{item.Id}")"></video>
            @VideoCaption(movieItem.VideoFilePath, $"media/movie/{item.Id}")
        </div>
    }

    @if (item is TvShow tv)
    {
        <div class="mt-8 space-y-5">
            @if (matchError is not null)
            {
                <p class="rounded border border-rose-500/40 bg-rose-500/10 px-3 py-2 text-sm text-rose-300">@matchError</p>
            }
            @foreach (var season in tv.Seasons)
            {
                <div>
                    <h2 class="flex items-center gap-2 text-sm font-semibold text-white">
                        <span>
                            @(season.SeasonNumber == 0 ? "Specials" : $"Season {season.SeasonNumber}")
                            <span class="font-normal text-slate-500">· @season.Episodes.Count episode(s)</span>
                        </span>
                        @if (CanMatchEpisodes(tv))
                        {
                            <button class="ml-auto rounded border border-slate-700 px-2 py-0.5 text-xs font-normal text-slate-300 hover:bg-slate-800 disabled:opacity-50"
                                    disabled="@(busyId is not null)"
                                    title="Re-fetch metadata for this season's episodes and write their NFOs"
                                    @onclick="() => MatchSeason(season.Id)">
                                @(busyId == season.Id ? "Matching…" : "Match season")
                            </button>
                        }
                    </h2>
                    <div class="mt-2 divide-y divide-slate-800 rounded-lg border border-slate-800">
                        @foreach (var ep in season.Episodes)
                        {
                            <div class="px-3 py-2 text-sm">
                                <div class="flex items-baseline gap-3">
                                    <span class="font-mono text-xs text-slate-500">
                                        S@(season.SeasonNumber.ToString("00"))E@(ep.EpisodeNumber.ToString("00"))
                                    </span>
                                    <span class="text-slate-200">@(string.IsNullOrWhiteSpace(ep.Title) ? "—" : ep.Title)</span>
                                    <div class="ml-auto flex shrink-0 items-center gap-3">
                                        @if (ep.AirDate is { } air)
                                        {
                                            <span class="text-xs text-slate-500">@air.ToString("yyyy-MM-dd")</span>
                                        }
                                        @if (CanMatchEpisodes(tv))
                                        {
                                            <button class="text-xs text-slate-400 hover:text-slate-200 disabled:opacity-50"
                                                    disabled="@(busyId is not null)"
                                                    title="Re-fetch metadata for this episode and write its NFO"
                                                    @onclick="() => MatchEpisode(ep.Id)">
                                                @(busyId == ep.Id ? "Matching…" : "Match")
                                            </button>
                                        }
                                        @if (ep.VideoFilePath.Length > 0)
                                        {
                                            <button class="text-xs text-sky-400 hover:text-sky-300" @onclick="() => ToggleEpisode(ep.Id)">
                                                @(playingEpisodeId == ep.Id ? "Stop" : "▶ Play")
                                            </button>
                                        }
                                    </div>
                                </div>
                                @if (playingEpisodeId == ep.Id)
                                {
                                    <div class="mt-2">
                                        <video controls autoplay playsinline class="max-h-[70vh] w-full rounded bg-black"
                                               src="@($"media/episode/{ep.Id}")"></video>
                                        @VideoCaption(ep.VideoFilePath, $"media/episode/{ep.Id}")
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }

    <IdentifyDialog Visible="showIdentify"
                    ItemId="item.Id"
                    ItemTitle="@item.Title"
                    ItemYear="item.Year"
                    LibraryType="@(item is TvShow ? LibraryType.TvShows : LibraryType.Movies)"
                    PreferredSource="PreferredSource()"
                    OnClose="() => showIdentify = false"
                    OnLinked="OnChanged" />

    <RenamePreviewDialog Visible="showRename"
                         ItemId="item.Id"
                         ItemTitle="@item.Title"
                         OnClose="() => showRename = false"
                         OnApplied="OnChanged" />
}

@code {
    [Parameter] public Guid Id { get; set; }

    private MediaItem? item;
    private bool loaded;
    private bool showIdentify;
    private bool showRename;
    private bool showPlayer;
    private Guid? playingEpisodeId;
    private Guid? busyId;
    private string? matchError;
    private MetadataSource preferredTvSource = MetadataSource.Tmdb;
    private MetadataSource preferredMovieSource = MetadataSource.Tmdb;

    protected override async Task OnInitializedAsync()
    {
        var providers = (await SettingsService.GetAsync()).Providers;
        preferredTvSource = providers.PreferredTvSource;
        preferredMovieSource = providers.PreferredMovieSource;
        await LoadAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (loaded && item?.Id != Id)
        {
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        // Reset any open player when the item changes.
        showPlayer = false;
        playingEpisodeId = null;
        item = await MediaService.GetItemAsync(Id);
        loaded = true;
    }

    private void ToggleEpisode(Guid id) => playingEpisodeId = playingEpisodeId == id ? null : id;

    // Per-season / per-episode matching is only meaningful once the show itself is matched, since it
    // re-uses the show's provider link and episode order to look episodes up by number.
    private static bool CanMatchEpisodes(TvShow show) => show.PrimaryProvider != MetadataSource.None;

    private Task MatchSeason(Guid seasonId) => RunMatch(seasonId, () => IdentifyService.RefreshSeasonAsync(seasonId));

    private Task MatchEpisode(Guid episodeId) => RunMatch(episodeId, () => IdentifyService.RefreshEpisodeAsync(episodeId));

    private async Task RunMatch(Guid id, Func<Task> action)
    {
        if (busyId is not null)
        {
            return;
        }

        busyId = id;
        matchError = null;
        try
        {
            await action();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            matchError = ex.Message;
        }
        finally
        {
            busyId = null;
        }
    }

    // Filename + open-in-new-tab fallback, with a note when the container won't play inline.
    private RenderFragment VideoCaption(string videoPath, string url) =>@<p class="mt-2 flex flex-wrap items-center gap-x-2 text-xs text-slate-500">
        <span class="font-mono">@FileName(videoPath)</span>
        <span>·</span>
        <a class="text-sky-400 hover:text-sky-300" href="@url" target="_blank" rel="noopener">Open in new tab</a>
        @if (!VideoExtensions.IsBrowserPlayable(videoPath))
        {
            <span class="text-amber-400/80">— @ContainerLabel(videoPath) may not play in the browser; use “Open in new tab” or an external player.</span>
        }
    </p>;

    private static string FileName(string path) => System.IO.Path.GetFileName(path);

    private static string ContainerLabel(string path)
    {
        var ext = System.IO.Path.GetExtension(path).ToLowerInvariant();
        return string.IsNullOrEmpty(ext) ? "This file" : $"{ext} files";
    }

    private MetadataSource PreferredSource() =>
        item is TvShow ? preferredTvSource : preferredMovieSource;

    private async Task OnChanged()
    {
        showIdentify = false;
        showRename = false;
        await LoadAsync();
    }

    private static string InitialOf(string title) =>
        string.IsNullOrWhiteSpace(title) ? "?" : title[..1].ToUpperInvariant();

    private static string BadgeClass(MatchState state) => state switch
    {
        MatchState.Unmatched => "rounded px-2 py-0.5 text-xs font-medium bg-amber-500/20 text-amber-300",
        MatchState.Matched => "rounded px-2 py-0.5 text-xs font-medium bg-emerald-500/20 text-emerald-300",
        _ => "rounded px-2 py-0.5 text-xs font-medium bg-slate-600/30 text-slate-300",
    };
}
